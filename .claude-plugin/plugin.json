{
  "name": "ross-claude-toolkit",
  "version": "1.3.0",
  "description": "Cross-project skills and agents: systematic research workflows, code optimization, documentation management, adversarial plan review, and more.",
  "author": {
    "name": "baltwross"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/simplify-on-commit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/simplify-on-task-complete.sh",
            "timeout": 5,
            "statusMessage": "Checking if code simplification needed..."
          }
        ]
      }
    ]
  }
}
